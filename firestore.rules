rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is signed in
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    // users/{userId}
    match /users/{userId} {
      // Read: any authenticated user can read any user profile
      allow read: if isAuthenticated();
      // Write: only the owner can write their own document
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // listings/{listingId}
    match /listings/{listingId} {
      // Read: any authenticated user
      allow read: if isAuthenticated();
      // Create: authenticated user, and sellerId matches their UID
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid;
      // Update: listing owner can update anything;
      // a buyer can ONLY update the status field to 'sold' (when claiming)
      allow update: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          && request.resource.data.status == 'sold'
        )
      );
      allow delete: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
    }

    // orders/{orderId}
    match /orders/{orderId} {
      // Read/Update: only the buyer or seller
      allow read, update: if isAuthenticated() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      // Create: authenticated user, buyerId must equal request.auth.uid
      allow create: if isAuthenticated() && request.resource.data.buyerId == request.auth.uid;
      allow delete: if false;
    }

    // chats/{chatId}
    match /chats/{chatId} {
      // Read: allow if doc doesn't exist yet (for getOrCreate check) OR user is a participant
      allow read: if isAuthenticated() && (resource == null || request.auth.uid in resource.data.participants);
      // Create: authenticated user who lists themselves in participants
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      // Update: only existing participants
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow delete: if false;

      // messages subcollection inside chats
      match /messages/{messageId} {
        // Read: only if the requester is a participant in the parent chat
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        // Create: same participants check, and the message senderId equals their UID
        allow create: if isAuthenticated() && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                      request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // wallets/{userId}
    match /wallets/{userId} {
      // Read: only owner
      allow read: if isAuthenticated() && request.auth.uid == userId;
      // Write: deny all client writes (Cloud Functions only)
      allow write: if false; 
    }

    // transactions/{userId}/history/{transactionId}
    match /transactions/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if false; // Cloud Functions only

      match /history/{transactionId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if false; // Cloud Functions only
      }
    }

    // notifications/{userId}/items/{notificationId}
    match /notifications/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if false; // Cloud Functions only

      match /items/{notificationId} {
        allow read, update: if isAuthenticated() && request.auth.uid == userId;
        allow write: if false; // Cloud Functions only
      }
    }

    // platform/adminWallet
    match /platform/adminWallet {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only
    }

    // ratings/{ratingId}
    match /ratings/{ratingId} {
      // Read: any authenticated user
      allow read: if isAuthenticated();
      // Create: user must be the buyer (reviewer)
      allow create: if isAuthenticated() && request.resource.data.buyerId == request.auth.uid;
      allow update, delete: if false;
    }

    // expiryItems/{userId}/items/{itemId}
    match /expiryItems/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      
      match /items/{itemId} {
        // Read/Write: only owner
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
  }
}
